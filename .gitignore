# ── Drupal core / vendor ──────────────────────────────────────────────────────
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# ── Drupal files (user uploads, cache, private files) ─────────────────────────
/web/sites/default/files/
/web/sites/*/files/
/web/sites/*/private/

# ── Demo images (descargadas en entrypoint, no en repo) ───────────────────────
# Las imágenes se descargan via docker-entrypoint.sh en el primer deploy.

# ── Drupal settings ───────────────────────────────────────────────────────────
# settings.php reads from env vars — safe to commit
!/web/sites/default/settings.php
/web/sites/default/settings.local.php   # local overrides — git-ignored
/web/sites/default/services.yml

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Screenshots / imágenes de referencia local (no van al repo ni a Railway) ──
/*.png
/*.jpg
/*.jpeg

# ── OS / editor artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
/web/sites/default/files/php/

# ── Composer cache ────────────────────────────────────────────────────────────
/composer.phar

# ── Docker local override ─────────────────────────────────────────────────────
docker-compose.override.yml
.env.prod
