# ══════════════════════════════════════════════════════════════════════════════
#  PRODUCCIÓN — El Hogar de Corazón
#  Copia a .env.prod (git-ignorado) y ajusta TODOS los valores.
# ══════════════════════════════════════════════════════════════════════════════

# ── Caddy (HTTPS) ─────────────────────────────────────────────────────────────
# Pon aquí tu dominio. Si usas IP directa, escribe: http://1.2.3.4
CADDY_DOMAIN=demo.tudominio.com

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=CAMBIA_POR_CONTRASEÑA_SEGURA

MYSQL_DATABASE=drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=CAMBIA_POR_CONTRASEÑA_SEGURA
MYSQL_ROOT_PASSWORD=CAMBIA_ROOT_PASSWORD_SEGURA

# ── Drupal — Sitio ────────────────────────────────────────────────────────────
DRUPAL_SITE_NAME=El Hogar de Corazón
DRUPAL_SITE_MAIL=admin@hogarcorazon.org

# ── Drupal — Cuenta administrador ────────────────────────────────────────────
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASS=CAMBIA_POR_CONTRASEÑA_SEGURA

# ── Drupal — Hash salt ────────────────────────────────────────────────────────
# Genera uno nuevo con: openssl rand -base64 74
DRUPAL_HASH_SALT=REEMPLAZA_CON_VALOR_UNICO_GENERADO

# ── Drupal — Dominio de confianza (obligatorio en producción) ─────────────────
# Debe coincidir con el patrón del dominio. Usa ^ y $ como anclas:
DRUPAL_TRUSTED_HOST=^demo\.tudominio\.com$
