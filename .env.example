# ── Base de datos ──────────────────────────────────────────────────────────────
# Railway inyecta MYSQL_URL automáticamente cuando agregas el plugin MySQL.
# Para desarrollo local, usa las variables individuales:
DB_HOST=db
DB_PORT=3306
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=drupal

# ── MySQL (para docker-compose local) ────────────────────────────────────────
MYSQL_DATABASE=drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=drupal
MYSQL_ROOT_PASSWORD=rootpassword

# ── Drupal ────────────────────────────────────────────────────────────────────
DRUPAL_SITE_NAME=El Hogar de Corazón
DRUPAL_SITE_MAIL=admin@hogarcorazon.org
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASS=CambiarEnProduccion!

# Genera uno único con: drush eval "echo \Drupal\Component\Utility\Crypt::randomBytesBase64(55)"
DRUPAL_HASH_SALT=pQoKDIqukq0-KIQ9STmJEKINRVhkMr0zdwbIMBnYADOeJ7HlrspzAz-oyvdjMHpYVyngRishJA

# Dominio(s) permitidos separados por coma (Railway los da automáticamente)
# DRUPAL_TRUSTED_HOST=mi-sitio.up.railway.app,www.midominio.com

# APP_ENV=production
