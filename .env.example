# ══════════════════════════════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — El Hogar de Corazón
#  Copia este archivo a .env para desarrollo local (git-ignorado).
#  Para Railway: configura estas variables en el dashboard del servicio.
# ══════════════════════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────────────────────
# Railway MySQL plugin inyecta MYSQL_URL automáticamente — no lo configures tú.
# Solo se necesitan las variables individuales en desarrollo local:
DB_HOST=db
DB_PORT=3306
DB_NAME=drupal
DB_USER=drupal
DB_PASSWORD=drupal

# ── MySQL (solo para docker-compose local) ────────────────────────────────────
MYSQL_DATABASE=drupal
MYSQL_USER=drupal
MYSQL_PASSWORD=drupal
MYSQL_ROOT_PASSWORD=rootpassword

# ── Drupal — Sitio ────────────────────────────────────────────────────────────
DRUPAL_SITE_NAME=El Hogar de Corazón
DRUPAL_SITE_MAIL=admin@hogarcorazon.org

# ── Drupal — Cuenta administrador ────────────────────────────────────────────
# IMPORTANTE: cambia la contraseña antes del primer deploy en producción.
DRUPAL_ADMIN_USER=admin
DRUPAL_ADMIN_PASS=CambiarEnProduccion!

# ── Drupal — Hash salt (ÚNICO por ambiente) ───────────────────────────────────
# Genera uno con:
#   drush eval "echo \Drupal\Component\Utility\Crypt::randomBytesBase64(55);"
# Nunca uses el mismo salt en producción y en local.
DRUPAL_HASH_SALT=REEMPLAZA_CON_UN_VALOR_UNICO_GENERADO

# ── Drupal — Dominio(s) de confianza ─────────────────────────────────────────
# *.up.railway.app y *.railway.app ya están en settings.php.
# Solo agrega esta variable si usas un dominio propio:
# DRUPAL_TRUSTED_HOST=www.midominio.com

# ── Entorno ───────────────────────────────────────────════════════════════════
# Descomenta en producción para activar CSS/JS agregado y caché de página:
# APP_ENV=production
